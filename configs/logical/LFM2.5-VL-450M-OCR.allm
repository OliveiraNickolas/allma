# Logical model: LFM2.5-VL-450M-OCR
# Sampling otimizado para extração de texto em imagens (OCR/transcrição)
# Recomendações Liquid.ai:
# - temperature=0.1 → quasi-determinístico, consistente
# - min_p=0.15 → threshold de probabilidade
# - repetition_penalty=1.05 → evita repetições excessivas
# - max_tokens=1024 → limita respostas para eficiência

name = "LFM2.5-VL-450M-OCR"
physical = "LFM2.5-VL-450M"
enable_thinking = false

[sampling]
temperature = 0.1
top_p = 1.0
top_k = -1
min_p = 0.15
presence_penalty = 0.0
repetition_penalty = 1.05
max_tokens = 1024
