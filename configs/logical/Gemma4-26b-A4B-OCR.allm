# Logical model: Gemma4:26b-A4B-OCR
# Otimizado para OCR/transcrição de páginas escaneadas
# Vantagens sobre Qwen3.5-9b-OCR:
#   - Visão nativa (mmproj) → melhor entendimento de layouts complexos, diagramas, tabelas
#   - 26B de qualidade a custo de ~4B ativos (MoE)
# temperature=0 → greedy decoding: determinístico, sem alucinações
# penalties zerados → não suprimir palavras repetidas (textos reais repetem muito)
name = "Gemma4:26b-A4B-OCR"
physical = "Gemma4-26b-A4B-gguf"

[sampling]
temperature = 0.0
top_p = 1.0
top_k = -1
min_p = 0.0
presence_penalty = 0.0
repetition_penalty = 1.0
