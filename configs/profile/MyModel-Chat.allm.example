# Example: profile pointing to a base model.
# Copy to configs/profile/YourModel-Chat.allm and edit as needed.
#
# Thinking is enabled by default. Add @thinking-off to disable.

@name MyModel:chat
@base MyModel-GGUF
@thinking-off

temperature 0.7
top-p 0.9
top-k 40
min-p 0.0
presence-penalty 0.0
repetition-penalty 1.0
