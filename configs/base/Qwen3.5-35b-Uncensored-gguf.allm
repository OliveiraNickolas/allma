backend = "llama.cpp"
model = "/home/nick/AI/Models/Qwen3.5-35B-Uncensored-GGUF/Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive-Q6_K.gguf"
mmproj = "/home/nick/AI/Models/Qwen3.5-35B-Uncensored-GGUF/mmproj-Qwen3.5-35B-A3B-Uncensored-HauhauCS-Aggressive-f16.gguf"

# Core settings — MoE with kv_heads=2, KV cache ~1.2GB even at 131K context
n_ctx = 131072
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--chat-template-file", "/home/nick/AI/Models/Qwen3.5-35B-Uncensored-GGUF/chat_template.jinja",
    "--flash-attn", "on",
    "--split-mode", "layer",
    "--tensor-split", "1,1",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
