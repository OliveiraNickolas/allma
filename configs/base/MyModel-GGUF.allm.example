# Example: llama.cpp backend (GGUF model)
# Copy to configs/base/YourModel.allm and edit the paths.

@llamacpp
@path /path/to/your/model.gguf
@gpu 0

-ngl -1
-c 131072
-b 1024
-t 8
--no-warmup
--jinja
--flash-attn on
--cache-type-k q8_0
--cache-type-v q8_0
--ubatch-size 512
--threads-batch 16
--cont-batching

# Optional: enable vision support
# --mmproj /path/to/mmproj.gguf
