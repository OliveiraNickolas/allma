backend = "llama.cpp"
model = "/home/nick/AI/Models/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF/Qwen3.5-27B.Q8_0.gguf"
mmproj = "/home/nick/AI/Models/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF/Qwen3.5-27B.BF16-mmproj.gguf"

# Core settings — distillation fine-tune was trained on ~8K context; 32K for practical use
n_ctx = 32768
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--split-mode", "layer",
    "--tensor-split", "1,1",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
