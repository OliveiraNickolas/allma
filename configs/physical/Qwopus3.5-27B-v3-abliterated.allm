backend = "llama.cpp"
model = "/home/nick/AI/Models/Qwopus3.5-27B-v3-abliterated/Qwopus3.5-27B-v3-abliterated.gguf"
mmproj = "/home/nick/AI/Models/Qwopus3.5-27B-v3-abliterated/mmproj-Qwopus3.5-27B-v3-abliterated-f16.gguf"

# Dense 27B Q4_K_M (~16GB), single GPU 1 — 65K ctx ~1.8GB KV → ~21GB total, ~3GB livres
# Claude Code system prompt = ~36K tokens; 65K dá headroom suficiente
pinned_gpu = 1
n_ctx = 65536
n_batch = "2048"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "512",
    "--threads-batch", "8",
    "--cont-batching",
    "--defrag-thold", "0.1"
]
