# Physical model: Qwen3.5-27b (vLLM backend)
# Hardware: 2x RTX 3090 (no NVLink)
# Workload: coding, tool calling, long context

backend = "vllm"
path = "/mnt/ssd/home/nick/AI/Models/Qwen3.5-27B-GPTQ-Int4"
tokenizer = "/mnt/ssd/home/nick/AI/Models/Qwen3.5-27B-GPTQ-Int4"
tensor_parallel = "2"
gpu_memory_utilization = "0.92"
max_model_len = 131072
max_num_seqs = 2
max_num_batched_tokens = 8192

extra_args = [
    "--reasoning-parser", "qwen3",
    "--enable-auto-tool-choice",
    "--tool-call-parser", "qwen3_coder",
    "--disable-custom-all-reduce",
    "--enable-chunked-prefill",
    "--enable-prefix-caching",
    "--kv-cache-dtype", "fp8"
]
