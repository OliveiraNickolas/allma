backend = "llama.cpp"
model = "/home/nick/AI/Models/Gemma-4-A4B-Uncensored-GGUF/Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-Q8_K_P.gguf"
mmproj = "/home/nick/AI/Models/Gemma-4-A4B-Uncensored-GGUF/mmproj-Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-f16.gguf"

# Core settings — MoE with kv_heads=2, KV ~0.9GB even at 131K; fits on single GPU
n_ctx = 131072
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
