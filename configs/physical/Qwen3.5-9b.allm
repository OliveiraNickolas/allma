# Physical model: Qwen3.5-9b (vLLM backend)
# Hardware: 2x RTX 3090 TP=2 (auto-selected at runtime) — 24GB total
# Workload: fast responses, parallel requests, tool calling, OCR batching
# NOTE: max_model_len=32768 (32K tokens) fits in 24GB VRAM (~23.5GB) with FP16 KV cache
# FP8 is NOT supported on Ampere (3090) — only on Ada (4090+)

backend = "vllm"
path = "/home/nick/AI/Models/Qwen3.5-9b"
tokenizer = "/home/nick/AI/Models/Qwen3.5-9b"
tensor_parallel = 2
gpu_memory_utilization = "0.60"
max_model_len = 8192
max_num_seqs = 4
max_num_batched_tokens = 8192

extra_args = [
    "--reasoning-parser", "qwen3",
    "--enable-auto-tool-choice",
    "--tool-call-parser", "qwen3_coder",
    "--enable-prefix-caching"
]
