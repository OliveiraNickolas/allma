# Physical model: Qwen3.5-9b-Heretic (vLLM backend)

backend = "vllm"
path = "/home/nick/AI/Models/Qwen3.5-9B-Heretic"
tokenizer = "/home/nick/AI/Models/Qwen3.5-9B-Heretic"
tensor_parallel = "1"
