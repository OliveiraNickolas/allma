backend = "llama.cpp"
model = "/home/nick/AI/Models/Gemma-4-31B-GGUF/gemma-4-31B-it-UD-Q8_K_XL.gguf"
mmproj = "/home/nick/AI/Models/Gemma-4-31B-GGUF/mmproj-BF16.gguf"

n_ctx = 131072
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--split-mode", "layer",
    "--tensor-split", "1,1",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
