# Physical model: Gemma4-31b-gguf (llama.cpp backend)
# Hardware: 2x RTX 3090 (no NVLink) + Ryzen 9950X3D + 64GB DDR5
# Architecture: Dense 30.7B, 60 layers, GQA 16 kv heads, sliding window 1024
# Native context: 256K (no rope scaling needed)
# Features: multimodal (vision), native tool calling, thinking mode

backend = "llama.cpp"
model = "/mnt/ssd/home/nick/AI/Models/Gemma-4-31B-GGUF/gemma-4-31B-it-UD-Q8_K_XL.gguf"
mmproj = "/mnt/ssd/home/nick/AI/Models/Gemma-4-31B-GGUF/mmproj-BF16.gguf"

n_ctx = 131072
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--split-mode", "layer",
    "--tensor-split", "1,1",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
