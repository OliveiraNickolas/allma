backend = "llama.cpp"
model = "/home/nick/AI/Models/Qwopus3.5-9B-abliterated/Qwopus3.5-9B-abliterated.gguf"
mmproj = "/home/nick/AI/Models/Qwopus3.5-9B-abliterated/mmproj.gguf"

# Dense 9B Q8_0 (~8.9GB weights), dual-GPU split — 131K context fits comfortably in 48GB VRAM
n_ctx = 131072
n_batch = "4096"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--chat-template-file", "/home/nick/AI/Models/Qwopus3.5-9B-abliterated/chat_template.jinja",
    "--flash-attn", "on",
    "--split-mode", "layer",
    "--tensor-split", "1,1",
    "--main-gpu", "0",
    "--cache-type-k", "q8_0",
    "--cache-type-v", "q8_0",
    "--ubatch-size", "1024",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1",
    "--mlock"
]
