# Allama Remote Provider Configuration
# Copy this file to ~/.allama/.env and fill in your credentials
# IMPORTANT: Never commit .env to git (it contains API keys!)

# OpenCode API (https://opencode.ai)
OPENCODE_API_KEY=sk-...
OPENCODE_BASE_URL=https://api.opencode.io/v1

# OpenClaw API (https://docs.openclaw.ai)
OPENCLAW_API_KEY=...
OPENCLAW_BASE_URL=https://api.openclaw.ai/v1

# Future: Add more providers here
