# Allma Environment Configuration
# Copy this file to .env and adjust values as needed.

# Port for the Allma API server (OpenAI + Anthropic compatible)
ALLMA_PORT=9000

# First port for vLLM backend instances (increments for each loaded model)
VLLM_BASE_PORT=8000

# First port for llama.cpp backend instances
LLAMA_BASE_PORT=9001

# Path to the llama-server binary (auto-detected if not set)
# LLAMA_CPP_PATH=/usr/local/bin/llama-server

# Path to the vllm binary (auto-detected if not set)
# VLLM_PATH=/usr/local/bin/vllm

# Seconds of inactivity before an idle model is unloaded (default: 600)
KEEP_ALIVE_SECONDS=600

# Health check interval in seconds (default: 60)
HEALTH_CHECK_INTERVAL=60

# Minimum free VRAM (GB) required before loading a new model (default: 1.0)
GPU_MEMORY_THRESHOLD_GB=1.0

# Auto-unload idle models when VRAM is needed (default: true)
AUTO_SWAP_ENABLED=true

# Restrict Allma to specific GPUs (comma-separated GPU indices, e.g. "0,1")
# Leave unset to use all available GPUs.
# ALLMA_VISIBLE_DEVICES=0,1

# Maximum number of recent messages to keep per request (0 = unlimited).
# Agent frameworks (hermes-agent, etc.) generate many tool call messages per task —
# set this high enough or to 0. When truncation does happen, system + first user
# messages are always preserved so the model always has a query anchor.
MAX_MESSAGES=0

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Directory where allma download saves models (default: ~/AI/Models)
# ALLMA_MODELS_DIR=/data/models
